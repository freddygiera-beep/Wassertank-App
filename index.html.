<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SV Bernbach - Wassertank Echtzeit-Monitor</title>
    
    <meta name="theme-color" content="#1e293b">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/3105/3105807.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col justify-between font-sans antialiased">

    <header class="bg-slate-800 border-b border-slate-700 py-4 px-6 shadow-md">
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-blue-600 p-2.5 rounded-xl text-white shadow-lg shadow-blue-500/20">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
                        SV Bernbach <span class="text-xs bg-blue-500/20 text-blue-400 px-2.5 py-0.5 rounded-full font-semibold">Offline-App</span>
                    </h1>
                    <p class="text-xs text-slate-400">Physikalische Live-Integration mit persistentem Hintergrund-Fluss</p>
                </div>
            </div>
            
            <div class="flex flex-wrap items-center gap-3">
                <div id="cloudStatusBadge" class="flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 px-3 py-1.5 rounded-lg">
                    <span id="cloudStatusDot" class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span id="cloudStatusText" class="text-xs font-semibold text-emerald-400">App einsatzbereit</span>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-6xl w-full mx-auto p-4 lg:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 flex-grow">
        
        <div class="lg:col-span-5 flex flex-col gap-6">
            
            <div class="relative bg-slate-800 border border-slate-700/80 rounded-2xl p-5 shadow-xl overflow-hidden">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-md font-semibold text-slate-200 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4v2m0-6V4" />
                        </svg>
                        Pegel-Justierung (Ankerpunkt)
                    </h2>
                    <span class="text-xs text-slate-500">Zylinder: Ø 2.19m</span>
                </div>
                
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-sm mb-2">
                            <label for="gaugeSlider" class="text-slate-300 font-medium">Wert an der Tanknadel (0 - 220 cm)</label>
                            <span class="text-blue-400 font-bold" id="gaugeDisplayVal">170.0 cm</span>
                        </div>
                        <input type="range" id="gaugeSlider" min="0" max="220" step="0.1" value="170" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500 focus:outline-none" oninput="handleUserVolumeInput('slider')" onchange="saveStateLocally()">
                        <div class="flex justify-between text-xs text-slate-500 mt-1">
                            <span>0 cm (Leer)</span>
                            <span>110 cm (Mitte)</span>
                            <span>220 cm (Voll)</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 items-center pt-2">
                        <span class="text-xs text-slate-400">Präzise manuelle Eingabe:</span>
                        <div class="relative">
                            <input type="number" id="gaugeValue" min="0" max="220" step="0.1" value="170" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-3 py-1.5 text-center text-slate-100 font-bold focus:ring-2 focus:ring-blue-500 focus:outline-none" oninput="handleUserVolumeInput('input')" onchange="saveStateLocally()">
                            <span class="absolute right-3 top-1.5 text-sm text-slate-500">cm</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="relative bg-slate-800 border border-slate-700/80 rounded-2xl p-5 shadow-xl overflow-hidden">
                <h2 class="text-md font-semibold text-slate-200 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                    Aktive Zuläufe & Abgänge (Ventile)
                </h2>
                
                <div class="space-y-3 mb-5">
                    <div class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-2">Wasserzulauf (+)</div>
                    
                    <label class="flex items-center justify-between p-3 rounded-xl bg-slate-900/60 border border-slate-700/50 hover:bg-slate-900 cursor-pointer transition">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" id="tap1" onchange="handleCheckboxChange()" class="w-4 h-4 text-blue-600 bg-slate-700 border-slate-600 rounded focus:ring-blue-500">
                            <div class="text-left">
                                <div class="text-sm font-medium text-slate-200">Hauptleitung</div>
                                <div class="text-xs text-slate-400">Wasseranschluss • Leistung: 3.790 l/h</div>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2 py-1 rounded bg-emerald-500/10 text-emerald-400">+3.790 l/h</span>
                    </label>

                    <label class="flex items-center justify-between p-3 rounded-xl bg-slate-900/60 border border-slate-700/50 hover:bg-slate-900 cursor-pointer transition">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" id="tap2" onchange="handleCheckboxChange()" class="w-4 h-4 text-blue-600 bg-slate-700 border-slate-600 rounded focus:ring-blue-500">
                            <div class="text-left">
                                <div class="text-sm font-medium text-slate-200">2. Zulauf (Mittagsleitung)</div>
                                <div class="text-xs text-slate-400">Zulauf-Schnitt • Leistung: 1.783 l/h</div>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2 py-1 rounded bg-emerald-500/10 text-emerald-400">+1.783 l/h</span>
                    </label>
                </div>

                <div class="space-y-3">
                    <div class="text-xs font-semibold text-rose-400 uppercase tracking-wider mb-2">Verbraucher / Entnahme (-)</div>
                    
                    <label class="flex items-center justify-between p-3 rounded-xl bg-slate-900/60 border border-slate-700/50 hover:bg-slate-900 cursor-pointer transition">
                        <div class="flex items-center gap-3">
                            <input type="checkbox" id="drain1" onchange="handleCheckboxChange()" class="w-4 h-4 text-rose-600 bg-slate-700 border-slate-600 rounded focus:ring-rose-500">
                            <div class="text-left">
                                <div class="text-sm font-medium text-slate-200">Bewässerung Hauptplatz</div>
                                <div class="text-xs text-slate-400">Großregner-Kreis • 10.250 l/h</div>
                            </div>
                        </div>
                        <span class="text-xs font-semibold px-2 py-1 rounded bg-rose-500/10 text-rose-400">-10.250 l/h</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 flex flex-col gap-6">
            <div class="bg-slate-800 border border-slate-700/80 rounded-2xl p-5 shadow-xl">
                <h2 class="text-md font-semibold text-slate-200 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    2D-Tankquerschnitte (Wasserbewegung in Echtzeit)
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <div class="md:col-span-5 flex flex-col items-center">
                        <span class="text-xs font-semibold text-slate-400 mb-2">Frontansicht (Liegendzylinder)</span>
                        <div class="relative bg-slate-900/40 p-4 rounded-2xl border border-slate-700/40 w-full flex justify-center">
                            <canvas id="tankCanvas" width="160" height="160"></canvas>
                        </div>
                    </div>
                    <div class="md:col-span-7 flex flex-col items-center">
                        <span class="text-xs font-semibold text-slate-400 mb-2">Längsschnitt (Länge: 8,00m)</span>
                        <div class="relative bg-slate-900/40 p-4 rounded-2xl border border-slate-700/40 w-full flex justify-center">
                            <canvas id="tankSideCanvas" width="280" height="160"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="bg-slate-800 border border-slate-700/80 rounded-2xl p-4 shadow-lg flex flex-col justify-between">
                    <span class="text-xs text-slate-400 uppercase font-semibold">Inhalt aktuell</span>
                    <div class="my-2"><span id="literResult" class="text-2xl font-bold text-blue-400">0 Liter</span></div>
                    <span class="text-[11px] text-slate-500">Maximal: 30.000 l</span>
                </div>
                <div class="bg-slate-800 border border-slate-700/80 rounded-2xl p-4 shadow-lg flex flex-col justify-between">
                    <span class="text-xs text-slate-400 uppercase font-semibold">Füllgrad</span>
                    <div class="my-2"><span id="percentResult" class="text-2xl font-bold text-emerald-400">0.0 %</span></div>
                    <div class="w-full bg-slate-700 rounded-full h-1.5 mt-1">
                        <div id="percentBar" class="bg-emerald-500 h-1.5 rounded-full" style="width: 0%"></div>
                    </div>
                </div>
                <div class="bg-slate-800 border border-slate-700/80 rounded-2xl p-4 shadow-lg flex flex-col justify-between">
                    <span class="text-xs text-slate-400 uppercase font-semibold">Freies Volumen</span>
                    <div class="my-2"><span id="freeResult" class="text-2xl font-bold text-amber-400">0 Liter</span></div>
                    <span class="text-[11px] text-slate-500">Aufnahme-Puffer</span>
                </div>
            </div>

            <div class="bg-slate-800 border border-slate-700/80 rounded-2xl p-5 shadow-xl">
                <span class="text-xs text-slate-400 uppercase font-semibold">Aktueller Durchsatz (Netto)</span>
                <div class="text-lg font-bold mt-1 mb-2" id="netFlowDisplay">0 l/h</div>
                <div id="timeResult" class="text-sm text-slate-300 font-medium">Berechnung...</div>
            </div>
        </div>
    </main>

    <script>
        const maxVolume = 30000;
        const maxGauge = 220; 
        const r = 1.0926;    
        const length = 8.0;   

        let state = {
            anchoredVolume: 19260, 
            anchoredTimestamp: Date.now(), 
            tap1: false, 
            tap2: false,
            drain1: false
        };

        let currentCalculatedVolume = 19260; 
        let netFlowRatePerHour = 0; 
        let lastTimestamp = null;
        let waveOffset = 0;
        let isUserInteracting = false;

        window.onload = function() {
            const localCachedState = localStorage.getItem('svb_wassertank_state');
            if (localCachedState) {
                try {
                    const parsed = JSON.parse(localCachedState);
                    state.anchoredVolume = parsed.anchoredVolume;
                    state.anchoredTimestamp = parsed.anchoredTimestamp;
                    state.tap1 = parsed.tap1;
                    state.tap2 = parsed.tap2;
                    state.drain1 = parsed.drain1;
                } catch (e) { console.error(e); }
            }

            document.getElementById('tap1').checked = state.tap1;
            document.getElementById('tap2').checked = state.tap2;
            document.getElementById('drain1').checked = state.drain1;

            updateFlowRatesLocally();
            lastTimestamp = performance.now();
            requestAnimationFrame(physicsLoop);

            // Registrierung des PWA Offline Service-Workers
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('service-worker.js')
                .then(() => console.log("Service Worker aktiv (Offline-Modus bereit)"))
                .catch(err => console.log("Service Worker Fehler", err));
            }
        };

        function updateFlowRatesLocally() {
            let inflowRate = 0;
            if (document.getElementById('tap1').checked) inflowRate += 3790;
            if (document.getElementById('tap2').checked) inflowRate += 1783;

            let outflowRate = 0;
            if (document.getElementById('drain1').checked) outflowRate += 10250; 

            netFlowRatePerHour = inflowRate - outflowRate;
            calculateStaticMetrics();
        }

        function anchorCurrentVolume() {
            state.anchoredVolume = currentCalculatedVolume;
            state.anchoredTimestamp = Date.now();
            state.tap1 = document.getElementById('tap1').checked;
            state.tap2 = document.getElementById('tap2').checked;
            state.drain1 = document.getElementById('drain1').checked;
        }

        function handleCheckboxChange() {
            anchorCurrentVolume();
            updateFlowRatesLocally();
            localStorage.setItem('svb_wassertank_state', JSON.stringify(state));
        }

        function handleUserVolumeInput(source) {
            isUserInteracting = true;
            const slider = document.getElementById('gaugeSlider');
            const input = document.getElementById('gaugeValue');
            let val = 170;

            if (source === 'slider') {
                val = parseFloat(slider.value);
                input.value = val.toFixed(1);
            } else {
                val = parseFloat(input.value);
                if (isNaN(val)) val = 0;
                if (val < 0) val = 0;
                if (val > maxGauge) val = maxGauge;
                slider.value = val.toFixed(1);
            }

            document.getElementById('gaugeDisplayVal').innerText = val.toFixed(1) + " cm";
            currentCalculatedVolume = getLitersFromGauge(val);
            state.anchoredVolume = currentCalculatedVolume;
            state.anchoredTimestamp = Date.now();
            localStorage.setItem('svb_wassertank_state', JSON.stringify(state));
            calculateStaticMetrics();
        }

        function saveStateLocally() {
            isUserInteracting = false;
            anchorCurrentVolume();
            localStorage.setItem('svb_wassertank_state', JSON.stringify(state));
        }

        function physicsLoop(timestamp) {
            let dt = (timestamp - lastTimestamp) / 1000;
            lastTimestamp = timestamp;
            if (dt > 1.0) dt = 0.1;
            waveOffset += 2 * dt; 

            const elapsedSeconds = (Date.now() - state.anchoredTimestamp) / 1000;
            const flowRatePerSecond = netFlowRatePerHour / 3600;

            currentCalculatedVolume = state.anchoredVolume + (flowRatePerSecond * elapsedSeconds);
            if (currentCalculatedVolume > maxVolume) currentCalculatedVolume = maxVolume;
            if (currentCalculatedVolume < 0) currentCalculatedVolume = 0;

            let newGaugeValue = getGaugeFromLiters(currentCalculatedVolume);

            if (!isUserInteracting && document.activeElement !== document.getElementById('gaugeValue') && document.activeElement !== document.getElementById('gaugeSlider')) {
                document.getElementById('gaugeValue').value = newGaugeValue.toFixed(1);
                document.getElementById('gaugeSlider').value = newGaugeValue.toFixed(1);
                document.getElementById('gaugeDisplayVal').innerText = newGaugeValue.toFixed(1) + " cm";
            }

            updateUIMetrics();
            requestAnimationFrame(physicsLoop);
        }

        function calculateStaticMetrics() {
            let freeLitres = maxVolume - currentCalculatedVolume;
            const netFlowDisplay = document.getElementById('netFlowDisplay');
            
            if (netFlowRatePerHour > 0) {
                netFlowDisplay.innerHTML = `<span class="text-emerald-400 font-bold">+${netFlowRatePerHour.toLocaleString('de-DE')} l/h</span>`;
            } else if (netFlowRatePerHour < 0) {
                netFlowDisplay.innerHTML = `<span class="text-rose-400 font-bold">${netFlowRatePerHour.toLocaleString('de-DE')} l/h</span>`;
            } else {
                netFlowDisplay.innerHTML = `<span class="text-slate-400 font-bold">Stagnation (0 l/h)</span>`;
            }

            let timeParagraph = document.getElementById('timeResult');
            if (netFlowRatePerHour > 0) {
                if (freeLitres <= 10) {
                    timeParagraph.innerHTML = "<span class='text-emerald-400 font-bold'>Tank ist bereits voll!</span>";
                } else {
                    let hoursNeeded = freeLitres / netFlowRatePerHour;
                    let totalMinutes = Math.round(hoursNeeded * 60);
                    timeParagraph.innerHTML = `Voll in: <span class="text-emerald-400 font-bold">ca. ${Math.floor(totalMinutes / 60)} Std. ${totalMinutes % 60} Min.</span>`;
                }
            } else if (netFlowRatePerHour < 0) {
                if (currentCalculatedVolume <= 10) {
                    timeParagraph.innerHTML = "<span class='text-rose-400 font-bold'>Tank ist bereits leer!</span>";
                } else {
                    let hoursLeft = currentCalculatedVolume / Math.abs(netFlowRatePerHour);
                    let totalMinutes = Math.round(hoursLeft * 60);
                    timeParagraph.innerHTML = `Leer in: <span class="text-rose-400 font-bold">ca. ${Math.floor(totalMinutes / 60)} Std. ${totalMinutes % 60} Min.</span>`;
                }
            } else {
                timeParagraph.innerHTML = "<span class='text-slate-400'>Keine Füllstands-Änderung.</span>";
            }
        }

        function updateUIMetrics() {
            let percent = ((currentCalculatedVolume / maxVolume) * 100).toFixed(1);
            let freeLitres = Math.round(maxVolume - currentCalculatedVolume);
            
            document.getElementById('literResult').innerText = Math.round(currentCalculatedVolume).toLocaleString('de-DE') + " Liter";
            document.getElementById('percentResult').innerText = percent + " %";
            document.getElementById('percentBar').style.width = percent + "%";
            document.getElementById('freeResult').innerText = freeLitres.toLocaleString('de-DE') + " Liter";

            let fillRatio = currentCalculatedVolume / maxVolume;
            drawCircularTank(fillRatio);
            drawLengthwiseTank(fillRatio);
        }

        function getLitersFromGauge(gauge) {
            let fillRatio = gauge / maxGauge;
            let h = fillRatio * (2 * r);
            let volume = 0;
            if (h > 0 && h < (2 * r)) {
                let cosTerm = (r - h) / r;
                if (cosTerm < -1) cosTerm = -1;
                if (cosTerm > 1) cosTerm = 1;
                let alpha = 2 * Math.acos(cosTerm);
                let segmentArea = 0.5 * r * r * (alpha - Math.sin(alpha));
                volume = segmentArea * length * 1000;
            } else if (h >= (2 * r)) { volume = maxVolume; }
            return volume;
        }

        function getGaugeFromLiters(targetLiters) {
            if (targetLiters <= 0) return 0;
            if (targetLiters >= maxVolume) return maxGauge;
            let low = 0, high = maxGauge, guess = maxGauge / 2;
            for (let i = 0; i < 12; i++) {
                if (getLitersFromGauge(guess) < targetLiters) { low = guess; } else { high = guess; }
                guess = (low + high) / 2;
            }
            return guess;
        }

        function drawCircularTank(fillRatio) {
            const canvas = document.getElementById('tankCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const cx = canvas.width / 2, cy = canvas.height / 2, radius = canvas.width / 2 - 12;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            if (fillRatio > 0) {
                ctx.save();
                ctx.beginPath(); ctx.arc(cx, cy, radius, 0, Math.PI * 2); ctx.clip(); 
                let waterY = canvas.height - 12 - (fillRatio * (radius * 2));
                const gradient = ctx.createLinearGradient(0, waterY, 0, canvas.height);
                gradient.addColorStop(0, '#3b82f6'); gradient.addColorStop(1, '#1d4ed8');
                ctx.fillStyle = gradient; ctx.beginPath(); ctx.moveTo(0, canvas.height); ctx.lineTo(0, waterY);
                for (let x = 0; x <= canvas.width; x += 5) {
                    let y = waterY + Math.sin((x / 15) + waveOffset) * (4 * Math.sin(fillRatio * Math.PI));
                    ctx.lineTo(x, y);
                }
                ctx.lineTo(canvas.width, canvas.height); ctx.closePath(); ctx.fill(); ctx.restore();
            }
            ctx.beginPath(); ctx.arc(cx, cy, radius, 0, Math.PI * 2); ctx.lineWidth = 5; ctx.strokeStyle = '#475569'; ctx.stroke();
            ctx.fillStyle = fillRatio > 0.52 ? '#ffffff' : '#e2e8f0'; ctx.font = 'bold 15px sans-serif'; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
            ctx.fillText(Math.round(fillRatio * 100) + "%", cx, cy);
        }

        function drawLengthwiseTank(fillRatio) {
            const canvas = document.getElementById('tankSideCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            const x = 15, y = 15, width = canvas.width - 30, height = canvas.height - 30, r_corner = 18;
            
            const createTankPath = (context) => {
                context.beginPath(); context.moveTo(x + r_corner, y); context.lineTo(x + width - r_corner, y);
                context.quadraticCurveTo(x + width, y, x + width, y + r_corner); context.lineTo(x + width, y + height - r_corner);
                context.quadraticCurveTo(x + width, y + height, x + width - r_corner, y + height); context.lineTo(x + r_corner, y + height);
                context.quadraticCurveTo(x, y + height, x, y + height - r_corner); context.lineTo(x, y + r_corner);
                context.quadraticCurveTo(x, y, x + r_corner, y); context.closePath();
            };

            if (fillRatio > 0) {
                ctx.save(); createTankPath(ctx); ctx.clip();
                let waterY = y + height - (fillRatio * height);
                const gradient = ctx.createLinearGradient(0, waterY, 0, y + height);
                gradient.addColorStop(0, '#2563eb'); gradient.addColorStop(1, '#1d4ed8');
                ctx.fillStyle = gradient; ctx.beginPath(); ctx.moveTo(x - 5, y + height + 5); ctx.lineTo(x - 5, waterY);
                for (let px = x; px <= x + width; px += 8) {
                    ctx.lineTo(px, waterY + Math.sin((px / 20) - waveOffset) * (3 * Math.sin(fillRatio * Math.PI)));
                }
                ctx.lineTo(x + width + 5, y + height + 5); ctx.closePath(); ctx.fill(); ctx.restore();
            }
            createTankPath(ctx); ctx.lineWidth = 4; ctx.strokeStyle = '#475569'; ctx.stroke();
        }
    </script>
</body>
</html>
